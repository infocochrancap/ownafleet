# Copy this file to .env.local for local dev, or paste into Vercel env vars
# for production. DO NOT commit the real .env.local file.
#
# Scope: every variable below is set in Vercel → Project Settings →
# Environment Variables, with scope "Production + Preview" unless noted.

# ============================================================
# Supabase (server-side — secret key has full DB access)
# ============================================================
SUPABASE_URL=https://lkfaemhhdxjaqggvlotv.supabase.co
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ============================================================
# Resend (transactional email)
# ============================================================
RESEND_API_KEY=re_REPLACE_ME

# ============================================================
# Notification routing
# ============================================================
# Who gets emailed when a partner application comes in via /apply
# (partners.html → /api/apply-partner).
ADMIN_NOTIFY_EMAILS=josh@ownafleet.com

# DEPRECATED — /api/submit-lead no longer reads this. Notification email is
# hardcoded to josh@ownafleet.com only. Brian + Alondra get notified later
# in the funnel (booking + credit-app submission), not on form submit.
# LEAD_NOTIFY_EMAILS=brian@armadaequipment.com,alondra@bevelfinancial.com,josh@ownafleet.com

# ============================================================
# Calendly webhook (booking → auto status flip)
# ============================================================
# Random hex string generated by scripts/setup-calendly-webhook.js. Used by
# /api/calendly-webhook to verify the HMAC-SHA256 signature on every incoming
# webhook. If this is missing or wrong, webhook will reject all events.
CALENDLY_WEBHOOK_SIGNING_KEY=REPLACE_ME_HEX_STRING

# ============================================================
# Cron / scheduled jobs
# ============================================================
# Shared secret used by /api/cron-nudges to authenticate cron invocations.
# Vercel sets the Authorization: Bearer <CRON_SECRET> header on scheduled
# cron runs (vercel.json crons → /api/cron-nudges, daily at 16:00 UTC).
CRON_SECRET=REPLACE_ME_HEX_STRING

# ============================================================
# Email interaction logger
# ============================================================
# Bearer token that the Cloudflare Email Worker uses to POST inbound BCC
# mail (sent to log@ownafleet.com) into /api/log-interaction. Pair this
# value with the corresponding secret set in the Cloudflare Worker.
INTERACTION_LOG_API_KEY=REPLACE_ME_HEX_STRING

# ============================================================
# Armada credit application link (sent in the post-call email)
# ============================================================
# The URL Brian/operations provides for new participants to submit their
# credit application. Used by /api/send-application after the intro call.
ARMADA_APPLICATION_URL=https://example.armadaequipment.com/apply

# ============================================================
# Jotform application webhook
# ============================================================
# Shared secret for /api/jotform-webhook (Jotform doesn't sign webhooks, so
# auth is a ?key= query param). The webhook auto-flips a matched lead to
# 'application_submitted' when the credit application on /apply is submitted.
# Register in Jotform (Settings → Integrations → WebHooks) as:
#   https://ownafleet.com/api/jotform-webhook?key=<this value>
JOTFORM_WEBHOOK_KEY=REPLACE_ME_HEX_STRING

# ============================================================
# One-time setup ONLY — not a runtime env var, not needed in Vercel
# ============================================================
# CALENDLY_API_TOKEN — Personal Access Token from Calendly, used by
# scripts/setup-calendly-webhook.js to register the webhook subscription.
# After running setup once and saving the signing key above, REVOKE the
# token in Calendly → Integrations & apps → API & Webhooks.
